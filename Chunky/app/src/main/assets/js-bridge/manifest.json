{
  "manifest_version": 2,
  "name": "JS Bridge",
  "version": "1.0",
  "browser_specific_settings": { "gecko": { "id": "js-bridge@tvbrowser" } },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"], "all_frames": false, "run_at": "document_start" }],
  "permissions": ["nativeMessaging", "nativeMessagingFromContent", "geckoViewAddons"]
}